# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://copytrader:copytrader123@localhost:5432/copytrader

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis123@localhost:6379

# ─── Security ─────────────────────────────────────────────────────────────────
# JWT: generate with `openssl rand -hex 64`
JWT_SECRET=change-me-in-production-very-long-random-string
JWT_REFRESH_SECRET=change-me-too-another-very-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for Bull-ex credentials (AES-256)
ENCRYPTION_KEY=change-me-in-production-very-long-secret

# ─── Bull-ex Platform ─────────────────────────────────────────────────────────
BULLEX_API_URL=https://api.trade.bull-ex.com
BULLEX_WS_URL=wss://ws.trade.bull-ex.com/echo/websocket
BULLEX_PLATFORM_ID=580

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── Super Admin (primeiro login em /admin/login) ─────────────────────────────
# Se não existir nenhum usuário com role ADMIN, o backend cria um na subida usando:
INITIAL_ADMIN_EMAIL=admin@copy.com
INITIAL_ADMIN_PASSWORD=123456
INITIAL_ADMIN_NAME=Super Admin
